{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": [
      "**/*",
      "!.venv",
      "!.cache",
      "!.mypy_cache",
      "!.pytest_cache",
      "!__pycache__",
      "!build",
      "!build-*",
      "!toolchain",
      "!web-ui/dist",
      "!docs/.vitepress/dist",
      "!docs/.vitepress/cache",
      "!openwrt-support/luci-app-rtp2httpd/htdocs/luci-static/resources/view/rtp2httpd.js"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "lineWidth": 120,
    "indentStyle": "space"
  },
  "linter": {
    "rules": {
      "recommended": true
    }
  }
}
